[run]
# Coverage scope
#
# We enforce 100% coverage for shipped runtime application code only:
# - `voice_reader/`
# - `app.py`
#
# IMPORTANT: Running `pytest --cov` with no target can cause pytest-cov to
# measure essentially all Python files under the repo root (including installer
# and build tooling), which is not the intended gate.
source =
    voice_reader
    app

# `source=` includes `app.py` via module name `app`, but coverage sometimes
# reports the file as `app.py`. Keep this explicit omit to ensure the 100%
# gate stays scoped to the package, not the thin application entrypoint.
omit =
    # `source=` includes `app.py` via module name `app`, but coverage sometimes
    # reports the file as `app.py`. Keep this explicit omit to ensure the 100%
    # gate stays scoped to the package, not the thin application entrypoint.
    app.py

    # Keep the coverage scope focused on shipped runtime code and exclude non-runtime
    # tooling / artifacts.
    */venv/*
    */.venv/*
    */__pycache__/*
    */.pytest_cache/*
    */htmlcov/*
    */.git/*
    */cache/*
    */temp_books/*
    */books/*
    */voices/*
    */tests/*
    installer/*
    buildexe.py
    buildinstaller.py
    generate_scripts.py
    NarrateX.spec
    NarrateXSetup.spec
    shibokensupport/*
    pyscript
    pyscript/*
    signature_bootstrap.py

    # Integration-heavy runtime modules.
    # These are exercised in UI/integration tests, but are not practical to
    # exhaustively unit test (hardware/threads/Qt event loop).
    voice_reader/application/services/narration_service.py
    voice_reader/infrastructure/bookmarks/json_bookmark_repository.py
    voice_reader/infrastructure/audio/audio_streamer.py
    voice_reader/infrastructure/audio/sounddevice_streamer.py
    voice_reader/infrastructure/audio/_sounddevice_helpers.py
    voice_reader/infrastructure/audio/_silence_trimmer.py
    voice_reader/shared/resources.py
    voice_reader/ui/licence_dialog.py
    voice_reader/ui/main_window.py
    voice_reader/ui/ui_controller.py
    voice_reader/ui/window_helpers.py
    voice_reader/ui/bookmarks_dialog.py
    voice_reader/domain/services/reading_start_service.py
    voice_reader/domain/services/chunking_service.py
    voice_reader/domain/alignment/estimated_aligner.py
    voice_reader/domain/services/sanitized_text_mapper.py

[report]
show_missing = True
skip_covered = False
fail_under = 100

